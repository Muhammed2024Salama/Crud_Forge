{
    "name": "muhammedsalama/crudforge",
    "description": "Generate production-ready Laravel CRUD modules using a clean architecture package command.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "MuhammedSalama\\CrudForge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MuhammedSalama\\CrudForge\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "MuhammedSalama\\CrudForge\\CrudForgeServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:unit": "vendor/bin/phpunit --testsuite=\"CrudForge Test Suite\""
    }
}
