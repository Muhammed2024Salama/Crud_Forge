{
    "name": "muhammedsalama/crudforge",
    "description": "Generate production-ready Laravel CRUD modules using clean architecture — models, controllers, services, repositories, requests, resources, factories, tests, translations, and route snippets from a single Artisan command.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "crud",
        "generator",
        "scaffold",
        "artisan",
        "repository",
        "clean-architecture"
    ],
    "authors": [
        {
            "name": "Muhammed Salama",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "MuhammedSalama\\CrudForge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MuhammedSalama\\CrudForge\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.0|^3.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpstan/phpstan": "^1.12|^2.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "MuhammedSalama\\CrudForge\\CrudForgeServiceProvider",
                "MuhammedSalama\\CrudForge\\CrudForgeRuntimeServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:unit": "vendor/bin/phpunit --testsuite=\"CrudForge Test Suite\"",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=256M"
    }
}
